# Leave-check Kinect + OpenRouter checker
# Copy this file to `.env` in the repository root (same folder as README.md),
# then fill in your values. Do not commit `.env` (it is gitignored).

# Required: JSON GET returning {"items": ["keys", "badge", ...]}
CHECKLIST_URL=https://your-server.example/api/checklist

# Required: OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Vision-capable model slug on OpenRouter
OPENROUTER_MODEL=openai/gpt-4.1-mini

# Optional: POST when items are missing (omit to disable webhook)
WEBHOOK_URL=https://your-server.example/api/leave-webhook

# --- Optional checklist auth (use one) ---
# CHECKLIST_BEARER_TOKEN=your_token_here
# CHECKLIST_AUTH_HEADER=X-Custom-Auth: your_secret_here

# --- Optional webhook auth ---
# WEBHOOK_BEARER_TOKEN=your_token_here
# WEBHOOK_API_KEY_HEADER=x-api-key
# WEBHOOK_API_KEY_VALUE=your_key_here

# --- Optional alert sound (Linux / Raspberry Pi) ---
# Path to a WAV or MP3 file; aplay, paplay, or ffplay is used if on PATH.
# ALERT_SOUND_PATH=/home/pi/sounds/forgot_item.wav

# Optional: custom player; {path} is replaced with ALERT_SOUND_PATH
# ALERT_PLAYER_COMMAND=ffplay -nodisp -autoexit -loglevel quiet {path}
